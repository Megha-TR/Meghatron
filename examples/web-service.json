{
  "apiVersion": "v1",
  "kind": "Service",
  "metadata": {
    "name": "web-service",
    "namespace": "default"
  },
  "spec": {
    "type": "ClusterIP",
    "selector": {
      "app": "web"
    },
    "ports": [
      {
        "name": "http",
        "protocol": "TCP",
        "port": 8080,
        "targetPort": 80
      }
    ]
  }
}
