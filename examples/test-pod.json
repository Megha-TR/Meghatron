{
  "apiVersion": "v1",
  "kind": "Pod",
  "metadata": {
    "name": "test-pod",
    "namespace": "default"
  },
  "spec": {
    "restartPolicy": "Always",
    "containers": [
      {
        "name": "app",
        "image": "busybox:latest",
        "env": [
          {
            "name": "LOG_LEVEL",
            "value": "INFO"
          }
        ]
      }
    ]
  }
}
