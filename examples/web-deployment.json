{
  "apiVersion": "v1",
  "kind": "Deployment",
  "metadata": {
    "name": "web-server",
    "namespace": "default"
  },
  "spec": {
    "replicas": 3,
    "selector": {
      "app": "web"
    },
    "template": {
      "metadata": {
        "labels": {
          "app": "web"
        }
      },
      "spec": {
        "restartPolicy": "Always",
        "containers": [
          {
            "name": "nginx",
            "image": "nginx:1.24",
            "ports": [
              {
                "name": "http",
                "containerPort": 80,
                "protocol": "TCP"
              }
            ],
            "resources": {
              "requests": {
                "cpu": "100",
                "memory": "256"
              },
              "limits": {
                "cpu": "500",
                "memory": "512"
              }
            },
            "env": [
              {
                "name": "NGINX_WORKER_PROCESSES",
                "value": "4"
              }
            ]
          }
        ]
      }
    }
  }
}
